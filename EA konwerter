║ E) STATE MACHINE DIAGRAM (STM)                                    ║
╚═══════════════════════════════════════════════════════════════════╝

  [*] --> Idle

  state Idle {
    [*] --> WaitingForInput
    WaitingForInput : entry / resetForm()
    WaitingForInput : do / blinkCursor()
    WaitingForInput : exit / saveSnapshot()
    WaitingForInput --> Processing : submit [formValid] / validate()
  }

  state Processing {
    [*] --> Validating

    state Validating
    state Saving
    state Notifying

    Validating --> Saving : validated
    Saving --> Notifying : saved
    Notifying --> [*] : notified

    ' — Parallel regions —
    state Concurrent <<fork>>
    --
    state "Region A" as RA {
      [*] --> A1
      A1 --> A2
    }
    --
    state "Region B" as RB {
      [*] --> B1
      B1 --> B2
    }
  }

  Processing --> Complete : success
  Processing --> Error : failure / logError()

  state Error {
    Error : entry / showErrorDialog()
  }

  Error --> Idle : retry
  Error --> [*] : abandon

  Complete --> [*]

  ' — History —
  state "Parent" as PS {
    state "ChildA" as CA
    state "ChildB" as CB
    [H] --> CA : shallow history
    [H*] --> CB : deep history
  }

  ' — Choice pseudostate —
  state choice1 <<choice>>
  Processing --> choice1
  choice1 --> PathA : [condition1]
  choice1 --> PathB : [condition2]
  choice1 --> PathC : [else]

  ' — Junction pseudostate —
  state junction1 <<junction>>

  ' — Entry/Exit points —
  state SubMachine <<entryPoint>> : entryName
  state SubMachine <<exitPoint>> : exitName

  ' — Terminate —
  state terminate1 <<end>>

