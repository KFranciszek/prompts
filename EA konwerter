    P3 --> P2 : UserDTO
    P2 --> P1 : AuthResult(success)
    P1 ->> Q1 : publish(LoginEvent)
  else Porażka
    P3 --> P2 : AuthException
    P2 --> P1 : AuthResult(failure)
  end

